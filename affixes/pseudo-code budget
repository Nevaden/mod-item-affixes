FUNCTION CalculateItemStatBudget(itemLevel, slotType, numberOfSockets):
    // 1. Calculate Base Budget based on Era breakpoints
    IF itemLevel <= 66 THEN
        baseBudget = (itemLevel * 0.78) + 1.5
    ELSE IF itemLevel <= 114 THEN
        baseBudget = (itemLevel * 1.25) - 28.5
    ELSE
        baseBudget = (itemLevel * 1.92) - 105.0
    ENDIF

    // 2. Fetch the Slot Modifier to equalize Rings vs. Chests vs. Weapons
    slotModifiers = {
        "head": 1.0, "chest": 1.0, "legs": 1.0, "2h_weapon": 1.0,
        "shoulder": 0.74, "hands": 0.74, "waist": 0.74, "feet": 0.74,
        "1h_weapon": 0.54, "offhand": 0.54, "ring": 0.54, "neck": 0.54, "trinket": 0.54
    }
    
    modifier = slotModifiers.get(slotType.lower(), 1.0)
    totalItemBudget = baseBudget * modifier

    // Apply the Epic/Pinnacle loot bump (Lich King tier gear)
    totalItemBudget = totalItemBudget * 1.22 

    // 3. Deduct socket penalties before checking stat costs
    socketCost = numberOfSockets * 16
    availableBudget = totalItemBudget - socketCost

    RETURN MAX(0, availableBudget)
ENDFUNCTION


FUNCTION ValidateAndRollStats(itemLevel, slotType, numberOfSockets, isCasterWeapon, requestedStats):
    // Determine the exact budget pool this specific item size has
    totalAvailablePool = CalculateItemStatBudget(itemLevel, slotType, numberOfSockets)
    
    // Hardcoded WotLK Stat Exchange Rates (Point Cost per 1 unit of stat)
    statCosts = {
        "stamina": 1.0, "crit_rating": 1.0, "haste_rating": 1.0, "hit_rating": 1.0, 
        "mp5": 1.0, "armor_pen": 1.0, "strength": 1.0, "agility": 1.0, 
        "intellect": 1.0, "spirit": 1.0, "dodge_rating": 1.0, "defense_rating": 1.0, 
        "parry_rating": 1.0, "expertise": 1.0,
        "spell_power": 0.86,
        "attack_power": 0.5, "ranged_attack_power": 0.5
    }

    currentSpentBudget = 0
    finalRolledStats = EmptyDictionary()

    // Loop through the user's requested stats to construct cost validation
    FOR EACH statName, requestedValue IN requestedStats:
        
        // EXCEPTION: Caster Weapon Spell Power does not consume the budget pool
        IF statName == "spell_power" AND isCasterWeapon AND slotType CONTAINS "weapon" THEN
            maxAllowedSP = (itemLevel * 4.9) - 536
            IF requestedValue > maxAllowedSP THEN
                PRINT "Error: Spell Power violates Caster Weapon constraints. Max is " + maxAllowedSP
                finalRolledStats["spell_power"] = maxAllowedSP
            ELSE
                finalRolledStats["spell_power"] = requestedValue
            ENDIF
            CONTINUE // Skip to the next stat, this did not cost standard points
        ENDIF

        // Standard Stat Validation Calculation
        IF statCosts.contains(statName) THEN
            costPerStat = statCosts[statName]
            pointCostOfRequest = requestedValue * costPerStat

            // Track if total request overshoots remaining baseline
            IF (currentSpentBudget + pointCostOfRequest) > totalAvailablePool THEN
                // Scale down the requested amount to the highest legal remaining roll
                remainingPool = totalAvailablePool - currentSpentBudget
                maxPossibleValue = FLOOR(remainingPool / costPerStat)
                
                PRINT "Warning: " + statName + " truncated. Max allocation remaining is " + maxPossibleValue
                finalRolledStats[statName] = maxPossibleValue
                currentSpentBudget = totalAvailablePool // Budget is completely used up
            ELSE
                // Request is completely legal
                finalRolledStats[statName] = requestedValue
                currentSpentBudget = currentSpentBudget + pointCostOfRequest
            ENDIF
        ENDIF
    ENDFOR

    // Display leftover allocation points to user if they under-spent
    IF currentSpentBudget < totalAvailablePool THEN
        PRINT "Item rolled successfully. Remaining unused budget points: " + (totalAvailablePool - currentSpentBudget)
    ENDIF

    RETURN finalRolledStats
ENDFUNCTION
