@echo off
REM ============================================================
REM  mod-item-affixes -- Windows configuration
REM  Copy this file to config.bat and fill in every value.
REM  config.bat is gitignored -- your credentials stay local.
REM ============================================================

REM -- MySQL connection ---------------------------------------------------------
set MYSQL="C:\Program Files\MySQL\MySQL Server 8.4\bin\mysql.exe"
set MYSQL_HOST=127.0.0.1
set USER=acore
set PASS=YOUR_PASSWORD

REM -- Database names -----------------------------------------------------------
REM Default AzerothCore names. Change only if your install uses different names.
set DB_CHAR=acore_characters
set DB_WORLD=acore_world

REM -- Server DBC directory -----------------------------------------------------
REM Where your worldserver reads DBC files from.
REM Default AzerothCore layout: <root>\bin\data\dbc
set SERVER_DBC_DIR=C:\path\to\your\server\bin\data\dbc

REM -- WoW client Data directory ------------------------------------------------
REM Where MPQ patch files are written. Must be writable.
REM Default: C:\Program Files (x86)\World of Warcraft\Data
set CLIENT_DATA_DIR=C:\Program Files (x86)\World of Warcraft\Data

REM -- CMake build (optional) ---------------------------------------------------
REM Required only for scripts\manage\enable.bat and scripts\manage\disable.bat.
REM set CMAKE="C:\Program Files\CMake\bin\cmake.exe"
REM set BUILD_DIR=C:\path\to\your\azerothcore\build

REM -- MPQ patch suffix (optional) ----------------------------------------------
REM On first run the patch scripts auto-detect two free suffix letters (scanning
REM Z downward) and save them to scripts\local_config.bat for reuse. Uncomment
REM here to pin specific letters instead.
REM set PATCH_SUFFIX_DBC=Z
REM set PATCH_SUFFIX_SPELLS=Y

REM -- Custom ID ranges ---------------------------------------------------------
REM IDs this module inserts into shared world-DB tables and the DBC.
REM Change only if another mod already uses the same range, then re-run install.
set RUNE_ITEM_ID_START=602001
set IMPRINT_SPELL_ID_START=600001
set SPELLSWAP_SPELL_ID_START=699001
