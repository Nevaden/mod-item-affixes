# Normalize line endings to LF on check-in for all text files
* text=auto

*.cpp   text eol=lf
*.h     text eol=lf
*.sql   text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.cmake text eol=lf
*.conf  text eol=lf
*.dist  text eol=lf
*.json  text eol=lf
*.lua   text eol=lf
*.xml   text eol=lf
*.toc   text eol=lf
*.bat   text eol=crlf
*.ps1   text eol=crlf
*.sh    text eol=lf
*.csv   text eol=lf
